-- config.ld
project = "Lazarus"
title = "Lazarus Documentation"
description = "Architecture and API reference for the Lazarus engine"

-- Where your source code lives
file = "src"

-- Where the generated HTML documentation should be saved
dir = "doc"

-- Treat all documentation comments as Markdown
format = "markdown"

-- Include a README in the generated docs side-panel
readme = "README.md"

-- Sort functions alphabetically in the output (cleaner for huge projects)
sort = true
